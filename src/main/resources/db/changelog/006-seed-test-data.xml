<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="006-seed-test-users" author="dev">
        <loadData
                file="006-test-users.csv"
                relativeToChangelogFile="true"
                separator=","
                tableName="users"
                encoding="UTF-8">
            <column name="email" header="email" type="STRING"/>
            <column name="password_hash" header="password_hash" type="STRING"/>
        </loadData>
    </changeSet>

    <changeSet id="006-seed-test-seats" author="dev">
        <loadData
                file="006-test-seats.csv"
                relativeToChangelogFile="true"
                separator=","
                tableName="seats"
                encoding="UTF-8">
            <column name="seat_number" header="seat_number" type="STRING"/>
            <column name="status" header="status" type="STRING"/>
        </loadData>
    </changeSet>

</databaseChangeLog>
